{
  "name": "lacon-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "LACON - AI-powered content creation desktop app",
  "main": "dist/main/index.js",
  "author": "LACON Team",
  "license": "MIT",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "build:main": "tsc -p tsconfig.main.json",
    "build:preload": "tsc -p tsconfig.preload.json",
    "build:renderer": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.main.json --noEmit && tsc -p tsconfig.preload.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "package": "electron-builder --dir",
    "package:win": "electron-builder --win",
    "package:mac": "electron-builder --mac",
    "package:linux": "electron-builder --linux",
    "dist": "electron-builder",
    "dist:all": "electron-builder --win --mac --linux"
  },
  "dependencies": {
    "@huggingface/transformers": "^4.2.0",
    "@mozilla/readability": "^0.6.0",
    "@tiptap/core": "workspace:*",
    "@tiptap/extension-document": "workspace:*",
    "@tiptap/extension-highlight": "workspace:^",
    "@tiptap/extension-image": "workspace:^",
    "@tiptap/extension-link": "workspace:*",
    "@tiptap/extension-mention": "workspace:^",
    "@tiptap/extension-paragraph": "workspace:*",
    "@tiptap/extension-table": "workspace:^",
    "@tiptap/extension-table-cell": "workspace:^",
    "@tiptap/extension-table-header": "workspace:^",
    "@tiptap/extension-table-row": "workspace:^",
    "@tiptap/extension-task-item": "workspace:^",
    "@tiptap/extension-task-list": "workspace:^",
    "@tiptap/extension-text": "workspace:*",
    "@tiptap/extension-text-align": "workspace:^",
    "@tiptap/extension-text-style": "workspace:^",
    "@tiptap/extension-underline": "workspace:^",
    "@tiptap/extension-youtube": "workspace:^",
    "@tiptap/html": "workspace:*",
    "@tiptap/markdown": "workspace:*",
    "@tiptap/pm": "workspace:*",
    "@tiptap/react": "workspace:*",
    "@tiptap/starter-kit": "workspace:*",
    "@tiptap/suggestion": "workspace:^",
    "cheerio": "^1.2.0",
    "docx": "^9.6.1",
    "dompurify": "^3.2.2",
    "electron-updater": "^6.3.9",
    "linkedom": "^0.18.12",
    "pptxgenjs": "^4.0.1",
    "tippy.js": "^6.3.7",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.10.3",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "lucide-react": "^1.8.0",
    "postcss": "^8.4.49",
    "postcss-import": "^15.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "tslib": "^2.8.1",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.2"
  }
}
